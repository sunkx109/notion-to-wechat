# Notion Integration Token（https://www.notion.so/my-integrations 创建）
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxx

# 微信公众号 AppID 和 AppSecret（公众号后台 → 设置与开发 → 基本配置）
WECHAT_APP_ID=wxXXXXXXXXXXXXXXXX
WECHAT_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion 数据库 ID（可选，用于批量模式）
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
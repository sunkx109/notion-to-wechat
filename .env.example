# ============================================================
# Notion Publisher — 环境变量配置
# ============================================================
# 使用方法:
#   cp .env.example .env
#   然后编辑 .env 填入你的真实密钥
#
# .env 在 .gitignore 中，不会被提交到 git
# ============================================================

# ── Notion Integration Token ──────────────────────────────
# 获取方式: https://www.notion.so/my-integrations → 新建集成 → 复制 Internal Integration Secret
# 注意: 创建后需要把 Notion 页面连接到该集成（页面右上角 ... → 连接 → 选择你的集成）
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxx

# ── 微信公众号 ────────────────────────────────────────────
# 获取方式: mp.weixin.qq.com → 设置与开发 → 基本配置 → 公众号开发信息
# 需要: AppID + AppSecret（开发者密码）
# 注意: 首次使用还需扫码登录（脚本自动弹出二维码）
WECHAT_APP_ID=wxXXXXXXXXXXXXXXXX
WECHAT_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Notion 数据库 ID（可选）──────────────────────────────
# 用于批量模式，从数据库筛选待发布文章
# NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
